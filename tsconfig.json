{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next_e2e/types/**/*.ts",
    ".next_gen5/types/**/*.ts",
    ".next_gen5/types/**/*.ts",
    ".next_gen6/types/**/*.ts",
    ".next_gen6/types/**/*.ts",
    ".next_gen6_unique_789/types/**/*.ts",
    ".next_gen6_unique_789/types/**/*.ts",
    ".next_gen8/types/**/*.ts",
    ".next_worker10_v2/types/**/*.ts",
    ".next_worker11/types/**/*.ts",
    "next-env.d.ts",
    "next-env.d.ts",
    ".next_gen10/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
