#!/bin/bash

echo "=== Clean Shielded Build and Test Script ==="
cd "/home/wfowlkes/Claude Main Projects/SaasX/saasx-platform"

# 1. Kill all existing node/npm/next/tsx processes to start clean
echo "Killing all existing Node/Npm/Next/Tsx processes..."
pkill -9 -f "next build" || true
pkill -9 -f "processChild.js" || true
pkill -9 -f "tsx tests" || true
pkill -9 -f "node server.js" || true
pkill -9 -f "npm run build" || true
pkill -9 -f "npm exec tsx" || true

# 2. Clean port 3002
fuser -k 3002/tcp || true

# 3. Clean .next directory
echo "Cleaning .next directory..."
rm -rf .next

# 4. Start the shield loop in the background
MY_PID=$$
echo "Starting shield loop. My PID is $MY_PID"

shield_loop() {
  while true; do
    PIDS=$(pgrep -f "next build|processChild.js")
    for p in $PIDS; do
      if [ "$p" -ne "$MY_PID" ]; then
        CP=$p
        IS_DESCENDANT=false
        CHAIN=""
        while [ -n "$CP" ] && [ "$CP" -gt 1 ] 2>/dev/null; do
          PP=$(ps -o ppid= -p "$CP" 2>/dev/null | xargs)
          if [ -z "$PP" ] || ! [[ "$PP" =~ ^[0-9]+$ ]]; then
            break
          fi
          if [ "$PP" -eq "$MY_PID" ]; then
            IS_DESCENDANT=true
            break
          fi
          CP=$PP
        done
        
        if [ "$IS_DESCENDANT" = false ]; then
          echo "Shield: Killing competing process $p (chain: $p $CHAIN, MY_PID: $MY_PID)"
          kill -9 "$p" 2>/dev/null || true
        fi
      fi
    done
    sleep 1
  done
}

shield_loop &
SHIELD_PID=$!
echo "Shield loop started with PID $SHIELD_PID"

# 5. Run Next.js production build
echo "Running Next.js production build..."
export NODE_OPTIONS='--max-old-space-size=2048'
npm run build
BUILD_STATUS=$?

echo "Next.js build finished with code $BUILD_STATUS"

# 6. Kill the shield loop
kill -9 "$SHIELD_PID"
echo "Shield loop stopped."

if [ $BUILD_STATUS -ne 0 ]; then
  echo "Build failed. Exiting."
  exit $BUILD_STATUS
fi

# 7. Start E2E tests
echo "Starting E2E tests on port 3002..."
export PORT=3002
export PUPPETEER_EXECUTABLE_PATH="/usr/bin/google-chrome"
npx tsx tests/run-all.ts
TEST_STATUS=$?

echo "Tests finished with code $TEST_STATUS"
exit $TEST_STATUS
